# Server (required — see server.ts; app won't start if these are missing)
# HOSTNAME: the host the server binds to and serves on.
#   - "localhost" = only this computer can open the app.
#   - "0.0.0.0" = listen on all network interfaces so other devices on the
#     same network can reach it (e.g. phones/tablets on the warehouse Wi-Fi).
HOSTNAME=localhost
# PORT: the port the server listens on. The app will be at http://HOSTNAME:PORT
PORT=3000

# APP_ORIGIN (optional): the exact browser address users open the app from.
# It's used as the allowed CORS origin for the Socket.IO (live updates)
# connection — if it doesn't match the URL in the browser, real-time updates
# will be blocked by the browser.
# Defaults to http://HOSTNAME:PORT, so you only need to set this when users
# reach the app by a different address than the server binds to — typically by
# LAN IP, e.g. APP_ORIGIN=http://192.168.1.50:3000
# APP_ORIGIN=http://localhost:3000

# Microsoft SQL Server (required — see src/lib/db.ts)
DB_HOST=localhost
# Port SQL Server listens on (default 1433).
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=your_password_here
DB_NAME=pickstock-carcas-counters
# Encrypt the connection. Leave "false" for a local/LAN server without a
# CA-signed certificate; set "true" for managed services like Azure SQL.
DB_ENCRYPT=false
# Trust a self-signed server certificate. Keep "true" for local/LAN servers.
# Set "false" only when the server has a properly trusted certificate.
DB_TRUST_SERVER_CERT=true
